datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

model User {
  id          Int     @id @default(autoincrement())
  email       String  @unique
  password    String
  first_name  String
  last_name   String
  phone       String? 
  age         Int?
}